      "name": "OpenAI",
      "description": "OpenAI GPT系列模型，支持多种翻译任务",
      "base_url": "https://api.openai.com/v1",
      "models": [
        "gpt-4",
        "gpt-4-turbo",
        "gpt-3.5-turbo",
        "gpt-4o",
        "gpt-4o-mini"
      ],
      "default_model": "gpt-4",
      "auth_type": "bearer",
      "api_key_header": "Authorization",
      "api_key_format": "Bearer {key}",
      "max_tokens": 4096,
      "supports_stream": false,
      "requests_per_minute": 60,
      "tokens_per_minute": 150000
    },
    "claude": {
